struct Colour
    r : u8
    g : u8
    b : u8
    a : u8
end

C$InitWindow ( i32 i32 str -> )
C$CloseWindow ( -> )
C$WindowShouldClose ( -> i32 )

C$BeginDrawing ( -> )
C$EndDrawing ( -> )

C$ClearBackground( Colour -> )

800 600 "Hello from Arrowlang" InitWindow
while WindowShouldClose! loop
    BeginDrawing
    255 0 0 255 Colour ClearBackground
    EndDrawing
end
CloseWindow
0
