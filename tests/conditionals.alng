import errors

2 3 <  if 1 else 0 end 1 = "2 < 3"     errors::assert
2 3 >  if 1 else 0 end 0 = "!(2 > 3)"  errors::assert |
3 2 >  if 1 else 0 end 1 = "3 > 2"     errors::assert |
3 2 =  if 1 else 0 end 0 = "3 != 2"    errors::assert |
3 3 =  if 1 else 0 end 1 = "3 = 3"     errors::assert |
3 3 >  if 1 else 0 end 0 = "!(3 > 3)"  errors::assert |
3 3 >= if 1 else 0 end 1 = "3 >= 3"    errors::assert |
3 3 <  if 1 else 0 end 0 = "!(3 < 3)"  errors::assert |
3 3 <= if 1 else 0 end 1 = "3 <= 3"    errors::assert |
3 3 != if 1 else 0 end 0 = "!(3 != 3)" errors::assert |
3 4 != if 1 else 0 end 1 = "3 != 4"    errors::assert |
